{
  "manifest_version": 3,
  "name": "ScopeStack Quality of Life Buttons",
  "version": "1.5",
  "description": "Adds Add New buttons to ScopeStack pages and product selection tools. Developed by Matt Urbano (https://github.com/burn56/scopestack-hacks/tree/main/extensions/chrome/scopeStack-quality-of-life-buttons)",
  "icons": {
    "16": "icon16.png",
    "32": "icon32.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "content_scripts": [
    {
      "matches": [
		  "https://app.scopestack.io/admin/questionnaires/*/calculations/*/edit",
		  "https://app.scopestack.io/admin/questionnaires/*/recommendations/*/edit",
		  "https://app.scopestack.io/projects/*",
		  "https://app.scopestack.io/*/projects/*",
		  "https://app.scopestack.io/projects/*/project_materials",
		  "https://app.scopestack.io/*/projects/*/project_materials"
		],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}